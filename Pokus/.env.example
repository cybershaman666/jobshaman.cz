JOB_AGENT_RUNTIME_DIR=/tmp/job-agent

OLLAMA_BASE_URL=http://127.0.0.1:11434
OLLAMA_MODEL=glm-4.7-flash
OLLAMA_TIMEOUT_S=90

JOB_AGENT_DRY_RUN=true
JOB_AGENT_LIMIT=40

JOBSHAMAN_API_BASE=https://api.jobshaman.cz
JOBSHAMAN_API_FALLBACKS=https://site--jobshaman--rb4dlj74d5kc.code.run,https://jobshaman-cz.onrender.com
JOBSHAMAN_SEARCH_ENDPOINT=/jobs/hybrid-search-v2
JOBSHAMAN_APPLY_ENDPOINT=/jobs/applications
JOBSHAMAN_ACCESS_TOKEN=
JOBSHAMAN_CSRF_TOKEN=
JOBSHAMAN_VERIFY_SSL=true

WWR_API_URL=https://weworkremotely.com/categories/remote-programming-jobs.rss

