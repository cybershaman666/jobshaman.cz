{
    "headers": [
        {
            "source": "/(.*)",
            "headers": [
                {
                    "key": "Content-Security-Policy",
                    "value": "default-src 'self'; base-uri 'none'; form-action 'self'; frame-ancestors 'none'; script-src 'self' https://esm.sh; style-src 'self' https://fonts.googleapis.com 'unsafe-inline'; font-src 'self' https://fonts.gstatic.com data:; img-src 'self' data: https:; connect-src 'self' https://*.supabase.co https://site--jobshaman--rb4dlj74d5kc.code.run https://nominatim.openstreetmap.org https://ipapi.co; worker-src 'self' blob:; manifest-src 'self';"
                }
            ]
        }
    ],
    "rewrites": [
        {
            "source": "/api/v2/:path*",
            "destination": "https://site--jobshaman--rb4dlj74d5kc.code.run/:path*"
        },
        {
            "source": "/sitemap.xml",
            "destination": "https://site--jobshaman--rb4dlj74d5kc.code.run/sitemap.xml"
        },
        {
            "source": "/sitemap-pages.xml",
            "destination": "https://site--jobshaman--rb4dlj74d5kc.code.run/sitemap-pages.xml"
        },
        {
            "source": "/sitemap-clusters.xml",
            "destination": "https://site--jobshaman--rb4dlj74d5kc.code.run/sitemap-clusters.xml"
        },
        {
            "source": "/sitemap-jobs.xml",
            "destination": "https://site--jobshaman--rb4dlj74d5kc.code.run/sitemap-jobs.xml"
        },
        {
            "source": "/seo/(.*)",
            "destination": "https://site--jobshaman--rb4dlj74d5kc.code.run/seo/$1"
        },
        {
            "source": "/(.*)",
            "has": [
                { "type": "host", "value": "jobshaman.com" }
            ],
            "destination": "/index.en.html"
        },
        {
            "source": "/(.*)",
            "has": [
                { "type": "host", "value": "www.jobshaman.com" }
            ],
            "destination": "/index.en.html"
        },
        {
            "source": "/(.*)",
            "destination": "/index.html"
        }
    ]
}
