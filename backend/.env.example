# Security
SECRET_KEY=
JWT_SECRET=

# Database
MONGODB_URI=
MONGODB_DB=jobshaman
MONGODB_JCFPM_COLLECTION=jcfpm_items
MONGODB_DIALOGUE_AI_SUMMARIES_COLLECTION=dialogue_ai_summaries
MONGODB_DIALOGUE_TRANSCRIPTS_COLLECTION=dialogue_transcripts
MONGODB_DIALOGUE_FIT_EVIDENCE_COLLECTION=dialogue_fit_evidence
EXTERNAL_ASSET_STORAGE_MODE=local
EXTERNAL_ASSET_LOCAL_DIR=data/external_assets
EXTERNAL_ASSET_UPLOAD_SESSION_TTL_SECONDS=900
EXTERNAL_ASSET_DOWNLOAD_URL_TTL_SECONDS=15552000
EXTERNAL_ASSET_S3_ENDPOINT=
EXTERNAL_ASSET_S3_REGION=auto
EXTERNAL_ASSET_S3_BUCKET=
EXTERNAL_ASSET_S3_ACCESS_KEY_ID=
EXTERNAL_ASSET_S3_SECRET_ACCESS_KEY=
ROLE_DIALOGUE_PREVIEW_LIMIT=25
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_KEY=
SUPABASE_SERVICE_KEY=

# AI
OPENAI_API_KEY=
OPENAI_ENDPOINT=https://api.openai.com/v1/chat/completions
GEMINI_API_KEY=

# Payments
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# Email
RESEND_API_KEY=

# CORS
ALLOWED_ORIGINS=https://jobshaman.com,https://www.jobshaman.com,http://localhost:3000,http://localhost:5173

# Background jobs
ENABLE_BACKGROUND_SCHEDULER=false
ENABLE_MATCHING_BATCH_JOBS=false
ENABLE_DAILY_DIGESTS=false
ENABLE_PUBLIC_BENCHMARK_REFRESH=false

# Imported job APIs
ARBEITNOW_API_URL=https://www.arbeitnow.com/api/job-board-api
ARBEITNOW_MAX_PAGES=5
WWR_API_URL=https://weworkremotely.com/categories/remote-programming-jobs.rss
WWR_RSS_URLS=https://weworkremotely.com/categories/remote-programming-jobs.rss,https://weworkremotely.com/categories/remote-customer-support-jobs.rss,https://weworkremotely.com/categories/remote-sales-and-marketing-jobs.rss,https://weworkremotely.com/categories/remote-management-and-finance-jobs.rss,https://weworkremotely.com/categories/remote-product-jobs.rss,https://weworkremotely.com/categories/remote-design-jobs.rss,https://weworkremotely.com/categories/remote-devops-sysadmin-jobs.rss,https://weworkremotely.com/categories/all-other-remote-jobs.rss
GERMAN_TECH_JOBS_RSS_URL=https://germantechjobs.de/rss
SCRAPER_REMOTE_METADATA_BACKFILL=true
SCRAPER_REMOTE_METADATA_BACKFILL_BATCH_SIZE=200
SCRAPER_REMOTE_METADATA_BACKFILL_SLEEP_SECONDS=0.05
SCRAPER_REMOTE_METADATA_BACKFILL_MAX_ROWS=5000
