# JobShaman V2 frontend

# Prefer VITE_BACKEND_URL for deployed environments. If it does not end in
# /api/v2, the frontend ApiService will append /api/v2 automatically.
VITE_BACKEND_URL=http://localhost:8000

# Optional direct API override. When set, this should include /api/v2.
# VITE_API_URL=http://localhost:8000/api/v2
# VITE_V2_API_URL=http://localhost:8000/api/v2

# Supabase is auth-only in V2 frontend. Product data must go through /api/v2.
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# Existing billing integration, keep values aligned with current production setup.
VITE_BILLING_BACKEND_URL=
VITE_STRIPE_BACKEND_URL=

VITE_FEATURE_SALARY_BENCHMARKS=false
