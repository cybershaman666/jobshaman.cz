# Search API runtime
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
# Legacy alias
SUPABASE_SERVICE_KEY=
# Optional fallback if SUPABASE_SERVICE_KEY is not set
SUPABASE_KEY=

# Required for auth token/CSRF utilities
SECRET_KEY=
# or JWT_SECRET=
CSRF_TOKEN_EXPIRY=3600

# Comma-separated allowlist of FE origins
ALLOWED_ORIGINS=https://jobshaman.com,https://jobshaman.cz,https://www.jobshaman.com,https://www.jobshaman.cz,http://localhost:5173,http://localhost:3000

# Keep false in production
EXPOSE_DEBUG_ERRORS=false

# Render backend keep-awake (for free tier cold starts)
ENABLE_BACKEND_WAKE=true
BACKEND_WAKE_URL=https://jobshaman-cz.onrender.com/healthz
BACKEND_WAKE_INTERVAL_SECONDS=300
BACKEND_WAKE_TIMEOUT_SECONDS=65
BACKEND_WAKE_RETRIES=2
BACKEND_WAKE_RETRY_DELAY_SECONDS=8
